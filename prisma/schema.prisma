// SIDCUL Manufacturers Association — Hyper-Local Job Portal
// MongoDB data model for the MVP: companies post jobs, students apply.
// Roles, job types and statuses are stored as strings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// A single account. `role` is one of: STUDENT | COMPANY | ADMIN
model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String
  role         String   @default("STUDENT")
  name         String
  createdAt    DateTime @default(now())

  companyProfile CompanyProfile?
  studentProfile StudentProfile?
  applications   Application[]
}

/// Extra data for COMPANY accounts. Must be `verified` by an admin before posting.
model CompanyProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  about       String?
  location    String?
  website     String?
  sector      String? // Pharmaceuticals | FMCG & Packaging | Electrical & Auto | Allied Services
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  jobs Job[]
}

/// Extra data for STUDENT accounts.
model StudentProfile {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String
  phone     String?
  education String?
  skills    String?
  createdAt DateTime @default(now())
}

/// A job posting owned by a (verified) company.
model Job {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  companyId   String         @db.ObjectId
  company     CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  description String
  location    String
  jobType     String         @default("FULL_TIME") // FULL_TIME | PART_TIME | SHIFT | SEASONAL | INTERNSHIP
  sector      String?
  salary      String?
  status      String         @default("OPEN") // OPEN | CLOSED
  createdAt   DateTime       @default(now())

  applications Application[]
}

/// A student's application to a job. One application per student per job.
model Application {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId       String   @db.ObjectId
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId String   @db.ObjectId
  applicant   User     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  coverNote   String?
  resume      Resume?
  status      String   @default("APPLIED") // APPLIED | REVIEWED | SHORTLISTED | REJECTED
  createdAt   DateTime @default(now())

  @@unique([jobId, applicantId])
}

/// An uploaded résumé file, stored as binary data in MongoDB. One per Application.
/// The FK lives here (always non-null) so MongoDB's unique index never sees null dups.
model Resume {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  applicationId String      @unique @db.ObjectId
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  data          Bytes
  filename      String
  mimeType      String
  size          Int
  createdAt     DateTime    @default(now())
}

/// A read-only directory listing scraped from a public business directory.
/// Represents an IT/tech company located in the SIDCUL IT Park, Dehradun.
model DirectoryCompany {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  category    String?
  address     String?
  area        String?
  pincode     String?
  phone       String?
  email       String?
  website     String?
  description String?
  sourceUrl   String   @unique
  createdAt   DateTime @default(now())
}
